<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/textCrashTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/crash_detected_title"
        android:textColor="@color/hc_error"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textCrashMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/hc_text_primary" />

    <TextView
        android:id="@+id/textCrashMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/hc_text_secondary" />

    <TextView
        android:id="@+id/textCrashCountdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="@color/hc_warning"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
