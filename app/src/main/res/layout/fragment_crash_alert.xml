<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Waiting for crash detection..."
        android:textSize="18sp" />

    <TextView
        android:id="@+id/countdownText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="I'm OK (Cancel Alert)"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnSendSOS"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send SOS Now"
        android:visibility="gone" />

<!--    &lt;!&ndash; TEMP DEBUG BUTTON &ndash;&gt;-->
    <Button
        android:id="@+id/btnSimulateCrash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simulate Crash"
        android:layout_marginTop="16dp" />

</LinearLayout>
